# Maximus - exemplo de ambiente
# Copie para .env e preencha apenas no computador de operacao.
# Nunca envie .env real ao GitHub.

# ----------------------------------------
# Geral
# ----------------------------------------
TZ=America/Santarem
NODE_ENV=production

# ----------------------------------------
# Frontends Admin/Public - valores publicos do Supabase
# Obrigatorio para maximus-admin e maximus-public.
# Copie do painel do Supabase: Project Settings > API.
# Estas variaveis VITE_ ficam visiveis no navegador.
# ----------------------------------------
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_CHAVE_PUBLICA_ANON_OU_PUBLISHABLE

# ----------------------------------------
# Supabase privado - somente Docker/n8n/backend local
# Obrigatorio para workflows n8n que consultam RPCs privadas.
# Nunca use service role em codigo frontend.
# ----------------------------------------
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE=COLE_A_SERVICE_ROLE_APENAS_NO_ENV_LOCAL

# ----------------------------------------
# PostgreSQL local dos containers
# Obrigatorio para n8n e Evolution API locais.
# Use senhas novas no computador da hamburgueria.
# ----------------------------------------
POSTGRES_USER=maximus
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
N8N_POSTGRES_USER=maximus
N8N_POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_N8N
N8N_POSTGRES_DB=n8n
EVOLUTION_POSTGRES_USER=maximus
EVOLUTION_POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_EVOLUTION
EVOLUTION_POSTGRES_DB=evolution

# ----------------------------------------
# n8n
# Obrigatorio quando usar automacoes/WhatsApp.
# N8N_VERSION fica fixa para builds reproduziveis; atualize de forma planejada.
# ----------------------------------------
N8N_VERSION=1.123.65
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=TROQUE_POR_CHAVE_ALEATORIA_COM_32_OU_MAIS_CARACTERES
N8N_USER_MANAGEMENT_JWT_SECRET=TROQUE_POR_OUTRA_CHAVE_SEGURA

# ----------------------------------------
# Evolution API / WhatsApp
# Obrigatorio quando usar bot/WhatsApp.
# A URL interna abaixo e usada pelos containers; a porta local abre em 127.0.0.1.
# ----------------------------------------
EVOLUTION_PORT=8082
EVOLUTION_API_KEY=TROQUE_ESTA_CHAVE
EVOLUTION_INSTANCE_NAME=maximus
EVOLUTION_API_URL=http://127.0.0.1:8082

# ----------------------------------------
# IA / OpenAI
# Opcional. Necessario para fluxos n8n com transcricao, imagens ou IA.
# ----------------------------------------
OPENAI_API_KEY=

# ----------------------------------------
# Aplicativo desktop / atualizacoes
# Opcional. Use se houver um feed de atualizacao publicado.
# ----------------------------------------
MAXIMUS_UPDATE_URL=
